rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow anyone to read (view photos)
      allow read: if true;
      
      // Only you (the owner) can upload or delete
      allow write: if request.auth != null && 
                     request.auth.token.email == 'karthikeyankkarthik7@gmail.com' &&
                     request.auth.token.email_verified == true;
    }
  }
}
